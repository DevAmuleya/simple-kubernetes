pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "devamuleya/simple-kubernetes"
        DOCKER_TAG = "latest"
    }

    stages {

        stage('Clone') {
            steps {
                checkout scm
            }
        }

        stage('Build Image') {
            steps {
                // Use double quotes to allow Groovy variable expansion
                sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ./simple-kubernetes"
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds', // Make sure this matches Jenkins credential ID
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    // Using Groovy string interpolation
                    sh "echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin"
                }
            }
        }

        stage('Push Image') {
            steps {
                sh "docker push ${DOCKER_IMAGE}:${DOCKER_TAG}"
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                // Apply all YAMLs inside k8s folder
                sh 'kubectl apply -f ./k8s/'
            }
        }
    }

    post {
        success {
            echo "Pipeline completed successfully ✅"
        }
        failure {
            echo "Pipeline failed ❌"
        }
    }
}